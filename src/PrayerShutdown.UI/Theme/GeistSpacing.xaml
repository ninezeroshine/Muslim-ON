<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ SPACING SCALE (4px grid) ═══ -->
    <x:Double x:Key="GeistSpace0">0</x:Double>
    <x:Double x:Key="GeistSpace1">4</x:Double>
    <x:Double x:Key="GeistSpace2">8</x:Double>
    <x:Double x:Key="GeistSpace3">12</x:Double>
    <x:Double x:Key="GeistSpace4">16</x:Double>
    <x:Double x:Key="GeistSpace5">20</x:Double>
    <x:Double x:Key="GeistSpace6">24</x:Double>
    <x:Double x:Key="GeistSpace8">32</x:Double>
    <x:Double x:Key="GeistSpace10">40</x:Double>
    <x:Double x:Key="GeistSpace12">48</x:Double>
    <x:Double x:Key="GeistSpace16">64</x:Double>

    <!-- ═══ CORNER RADII ═══ -->
    <CornerRadius x:Key="GeistRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="GeistRadiusDefault">6</CornerRadius>
    <CornerRadius x:Key="GeistRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="GeistRadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="GeistRadiusXLarge">16</CornerRadius>
    <CornerRadius x:Key="GeistRadiusFull">9999</CornerRadius>

    <!-- ═══ BORDER THICKNESS ═══ -->
    <Thickness x:Key="GeistBorderThin">1</Thickness>
    <Thickness x:Key="GeistBorderThick">2</Thickness>

    <!-- ═══ COMMON PADDINGS ═══ -->
    <Thickness x:Key="GeistPagePadding">24,24,24,24</Thickness>
    <Thickness x:Key="GeistCardPadding">16,16,16,16</Thickness>
    <Thickness x:Key="GeistItemPadding">12,8,12,8</Thickness>

    <!-- ═══ SHADOWS ═══ -->
    <!-- WinUI uses ThemeShadow, but for custom cards we approximate with Border -->
</ResourceDictionary>
