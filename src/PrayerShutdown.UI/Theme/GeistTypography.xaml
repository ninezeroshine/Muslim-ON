<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font Family (fallback chain: Geist Sans -> Segoe UI Variable -> Segoe UI) -->
    <FontFamily x:Key="GeistSansFamily">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="GeistMonoFamily">Cascadia Mono, Consolas, monospace</FontFamily>

    <!-- ═══ HEADINGS ═══ -->
    <Style x:Key="GeistHeading1Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="56" />
        <Setter Property="CharacterSpacing" Value="-40" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistHeading2Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="44" />
        <Setter Property="CharacterSpacing" Value="-30" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistHeading3Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="32" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistHeading4Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="28" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistHeading5Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <!-- ═══ LABELS ═══ -->
    <Style x:Key="GeistLabelLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistLabelDefaultStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistLabelSmallStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <!-- ═══ BODY / COPY ═══ -->
    <Style x:Key="GeistBodyLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="26" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray900Brush}" />
    </Style>

    <Style x:Key="GeistBodyDefaultStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray900Brush}" />
    </Style>

    <Style x:Key="GeistBodySmallStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistSansFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray700Brush}" />
    </Style>

    <!-- ═══ MONO (countdown, numbers) ═══ -->
    <Style x:Key="GeistMonoLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistMonoFamily}" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>

    <Style x:Key="GeistMonoDefaultStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GeistMonoFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource GeistGray1000Brush}" />
    </Style>
</ResourceDictionary>
