<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrayerShutdown.UI.Views.ActionLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <StackPanel Padding="32,20,32,32" Spacing="16" MaxWidth="600" HorizontalAlignment="Center">
        <Grid>
            <TextBlock Text="{x:Bind ActivityLogTitle}" Style="{StaticResource GeistHeading3Style}" VerticalAlignment="Center" />
            <Button Content="{x:Bind ClearLabel}"
                    Style="{StaticResource GeistButtonTertiaryStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <!-- Empty state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="12" Padding="0,64,0,0">
            <FontIcon Glyph="&#xE81C;" FontSize="48"
                      Foreground="{ThemeResource GeistGray600Brush}"
                      HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind NoActivityTitle}"
                       Style="{StaticResource GeistHeading4Style}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind NoActivityDesc}"
                       Style="{StaticResource GeistBodyDefaultStyle}"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource GeistGray700Brush}" />
        </StackPanel>
    </StackPanel>
</Page>
