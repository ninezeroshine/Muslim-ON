<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrayerShutdown.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,20,32,32" Spacing="20" MaxWidth="720" HorizontalAlignment="Center">

            <TextBlock Text="{x:Bind L_Settings}" Style="{StaticResource GeistHeading3Style}" />

            <!-- ═══ LOCATION ═══ -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind L_Location}" Style="{StaticResource GeistHeading5Style}" />
                <TextBlock Text="{x:Bind L_LocationDesc}" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" />
                <Border Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="20"
                        BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind L_CurrentCity}" FontSize="12" FontWeight="Medium" Foreground="{ThemeResource GeistGray700Brush}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedCity, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource GeistGray1000Brush}" />
                        </StackPanel>
                        <AutoSuggestBox x:Name="CitySearch" PlaceholderText="{x:Bind L_SearchCity}" QueryIcon="Find"
                                        TextChanged="CitySearch_TextChanged" SuggestionChosen="CitySearch_SuggestionChosen" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══ CALCULATION METHOD ═══ -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind L_CalcMethod}" Style="{StaticResource GeistHeading5Style}" />
                <TextBlock Text="{x:Bind L_CalcMethodDesc}" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" TextWrapping="Wrap" />
                <Border Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="20"
                        BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <ComboBox Header="{x:Bind L_Method}" HorizontalAlignment="Stretch" x:Name="MethodCombo" SelectionChanged="MethodCombo_Changed">
                            <ComboBoxItem Content="{x:Bind L_MethodMwl}" Tag="MWL" />
                            <ComboBoxItem Content="{x:Bind L_MethodEgyptian}" Tag="Egyptian" />
                            <ComboBoxItem Content="{x:Bind L_MethodKarachi}" Tag="Karachi" />
                            <ComboBoxItem Content="{x:Bind L_MethodUmmAlQura}" Tag="UmmAlQura" />
                            <ComboBoxItem Content="{x:Bind L_MethodIsna}" Tag="ISNA" />
                            <ComboBoxItem Content="{x:Bind L_MethodTurkey}" Tag="Turkey" />
                            <ComboBoxItem Content="{x:Bind L_MethodTehran}" Tag="Tehran" />
                        </ComboBox>
                        <TextBlock Text="{x:Bind L_MethodRecommend}" FontSize="12" FontWeight="Medium"
                                   Foreground="{ThemeResource GeistBlue700Brush}" TextWrapping="Wrap" />
                        <ComboBox Header="{x:Bind L_AsrCalc}" HorizontalAlignment="Stretch" x:Name="AsrCombo" SelectionChanged="AsrCombo_Changed">
                            <ComboBoxItem Content="{x:Bind L_AsrShafi}" Tag="Shafi" />
                            <ComboBoxItem Content="{x:Bind L_AsrHanafi}" Tag="Hanafi" />
                        </ComboBox>
                        <ComboBox Header="{x:Bind L_HighLatRule}" HorizontalAlignment="Stretch" x:Name="HighLatCombo" SelectionChanged="HighLatCombo_Changed">
                            <ComboBoxItem Content="{x:Bind L_HighLatAngle}" Tag="AngleBased" />
                            <ComboBoxItem Content="{x:Bind L_HighLatMiddle}" Tag="NightMiddle" />
                            <ComboBoxItem Content="{x:Bind L_HighLatSeventh}" Tag="OneSeventh" />
                        </ComboBox>
                        <TextBlock Text="{x:Bind L_HighLatDesc}" FontSize="12" Foreground="{ThemeResource GeistGray600Brush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══ SHUTDOWN RULES ═══ -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind L_ShutdownRules}" Style="{StaticResource GeistHeading5Style}" />
                <TextBlock Text="{x:Bind L_ShutdownRulesDesc}" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" TextWrapping="Wrap" />
                <Border Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="20"
                        BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <ToggleSwitch Header="{x:Bind L_Fajr}" IsOn="{x:Bind ViewModel.ShutdownFajr, Mode=TwoWay}" />
                        <ToggleSwitch Header="{x:Bind L_Dhuhr}" IsOn="{x:Bind ViewModel.ShutdownDhuhr, Mode=TwoWay}" />
                        <ToggleSwitch Header="{x:Bind L_Asr}" IsOn="{x:Bind ViewModel.ShutdownAsr, Mode=TwoWay}" />
                        <ToggleSwitch Header="{x:Bind L_Maghrib}" IsOn="{x:Bind ViewModel.ShutdownMaghrib, Mode=TwoWay}" />
                        <ToggleSwitch Header="{x:Bind L_Isha}" IsOn="{x:Bind ViewModel.ShutdownIsha, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══ NOTIFICATIONS ═══ -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind L_Notifications}" Style="{StaticResource GeistHeading5Style}" />
                <TextBlock Text="{x:Bind L_NotificationsDesc}" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" TextWrapping="Wrap" />
                <Border Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="20"
                        BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <ToggleSwitch Header="{x:Bind L_ToastNotif}" IsOn="{x:Bind ViewModel.EnableNotifications, Mode=TwoWay}" />
                        <ToggleSwitch Header="{x:Bind L_AdhanSound}" IsOn="{x:Bind ViewModel.EnableAdhan, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══ APPEARANCE ═══ -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind L_Appearance}" Style="{StaticResource GeistHeading5Style}" />
                <Border Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="20"
                        BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <ComboBox Header="{x:Bind L_Language}" HorizontalAlignment="Stretch"
                                  x:Name="LanguageCombo" SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="English" />
                            <ComboBoxItem Content="Русский" />
                        </ComboBox>
                        <TextBlock Text="{x:Bind L_LanguageHint}" FontSize="12" Foreground="{ThemeResource GeistGray600Brush}" TextWrapping="Wrap" />
                        <ToggleSwitch Header="{x:Bind L_StartWindows}" IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}" />
                        <ToggleSwitch Header="{x:Bind L_StartMinimized}" IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══ SAVE ═══ -->
            <Button Content="{x:Bind L_SaveSettings}" Style="{StaticResource GeistButtonPrimaryStyle}"
                    HorizontalAlignment="Stretch" Height="40" Click="SaveButton_Click" />

            <InfoBar x:Name="SaveInfoBar" IsOpen="{x:Bind ViewModel.ShowStatus, Mode=OneWay}"
                     Severity="Success" Title="{x:Bind L_Saved}"
                     Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" IsClosable="True" />

        </StackPanel>
    </ScrollViewer>
</Page>
