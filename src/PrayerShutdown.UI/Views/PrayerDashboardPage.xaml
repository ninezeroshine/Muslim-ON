<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrayerShutdown.UI.Views.PrayerDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrayerShutdown.Features.PrayerDashboard"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="32,20,32,32" MaxWidth="600" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0: Header + Jumu'ah -->
                <RowDefinition Height="Auto" />  <!-- 1: Countdown -->
                <RowDefinition Height="Auto" />  <!-- 2: All done -->
                <RowDefinition Height="Auto" />  <!-- 3: No location -->
                <RowDefinition Height="Auto" />  <!-- 4: Error -->
                <RowDefinition Height="Auto" />  <!-- 5: Shutdown info -->
                <RowDefinition Height="Auto" />  <!-- 6: Progress bar -->
                <RowDefinition Height="Auto" />  <!-- 7: Day timeline -->
                <RowDefinition Height="Auto" />  <!-- 8: Section header -->
                <RowDefinition Height="Auto" />  <!-- 9: Prayer cards -->
                <RowDefinition Height="Auto" />  <!-- 10: Wisdom -->
                <RowDefinition Height="Auto" />  <!-- 11: Loading -->
            </Grid.RowDefinitions>

            <!-- ═══ ROW 0: Header ═══ -->
            <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="{x:Bind ViewModel.Greeting, Mode=OneWay}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{ThemeResource GeistGray1000Brush}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                        <Button Style="{StaticResource GeistButtonTertiaryStyle}"
                                Width="36" Height="36" Padding="0"
                                Visibility="{x:Bind ViewModel.ShowShutdownHint, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ExpandShutdownInfoCommand}"
                                ToolTipService.ToolTip="{x:Bind L_ShutdownHow}">
                            <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{ThemeResource GeistGray600Brush}" />
                        </Button>
                        <Button Style="{StaticResource GeistButtonTertiaryStyle}"
                                Width="36" Height="36" Padding="0"
                                Visibility="{x:Bind ViewModel.ShowWisdomHint, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ExpandWisdomCommand}"
                                ToolTipService.ToolTip="{x:Bind L_WisdomTitle}">
                            <FontIcon Glyph="&#xE82D;" FontSize="14" Foreground="{ThemeResource GeistGray600Brush}" />
                        </Button>
                        <Button Style="{StaticResource GeistButtonTertiaryStyle}"
                                Width="36" Height="36" Padding="0"
                                Command="{x:Bind ViewModel.ForceRefreshCommand}">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource GeistGray600Brush}" />
                        </Button>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.CurrentDate, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" />
                    <TextBlock Text="·" FontSize="13" Foreground="{ThemeResource GeistGray600Brush}" />
                    <TextBlock Text="{x:Bind ViewModel.HijriDate, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0" Visibility="{x:Bind ViewModel.HasLocation, Mode=OneWay}">
                    <FontIcon Glyph="&#xE81D;" FontSize="11" Foreground="{ThemeResource GeistGray600Brush}" />
                    <TextBlock Text="{x:Bind ViewModel.LocationName, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource GeistGray600Brush}" />
                    <TextBlock Text="·" FontSize="12" Foreground="{ThemeResource GeistGray600Brush}" />
                    <TextBlock Text="{x:Bind ViewModel.MethodName, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource GeistGray600Brush}" />
                </StackPanel>
                <!-- Jumu'ah banner (Feature 6) -->
                <Border CornerRadius="8" Padding="10,6" Margin="0,8,0,0"
                        Visibility="{x:Bind ViewModel.IsFriday, Mode=OneWay}"
                        Background="{ThemeResource GeistBlue100Brush}"
                        BorderBrush="{ThemeResource GeistBlue500Brush}" BorderThickness="1"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8D6;" FontSize="13" Foreground="{ThemeResource GeistBlue700Brush}" />
                        <TextBlock Text="{x:Bind ViewModel.FridayMessage, Mode=OneWay}" FontSize="12" FontWeight="Medium" Foreground="{ThemeResource GeistBlue700Brush}" />
                    </StackPanel>
                </Border>
                <!-- Update available banner -->
                <Border CornerRadius="8" Padding="12,8" Margin="0,8,0,0"
                        Visibility="{x:Bind ViewModel.UpdateAvailable, Mode=OneWay}"
                        Background="{ThemeResource GeistBackground200Brush}"
                        BorderBrush="{ThemeResource GeistGrayAlpha400Brush}" BorderThickness="1">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE896;" FontSize="16"
                                  Foreground="{ThemeResource GeistSuccessBrush}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind L_UpdateAvailable}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource GeistGray1000Brush}" />
                            <TextBlock FontSize="11" Foreground="{ThemeResource GeistGray700Brush}">
                                <Run Text="v" /><Run Text="{x:Bind ViewModel.UpdateVersion, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="{x:Bind L_UpdateNow}"
                                Style="{StaticResource GeistButtonPrimaryStyle}"
                                Height="30" Padding="14,0" FontSize="12"
                                Command="{x:Bind ViewModel.InstallUpdateCommand}"
                                Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InvertBoolVis}}" />
                        <ProgressBar Grid.Column="2" Width="80"
                                     Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay}"
                                     Value="{x:Bind ViewModel.UpdatePercent, Mode=OneWay}"
                                     Minimum="0" Maximum="100" Height="4" CornerRadius="2"
                                     Foreground="{ThemeResource GeistSuccessBrush}"
                                     VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ═══ ROW 1: Countdown ═══ -->
            <Border Grid.Row="1" Visibility="{x:Bind ViewModel.AllPrayersPassed, Mode=OneWay, Converter={StaticResource InvertBoolVis}}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="16" Padding="32,36,32,36" Margin="0,0,0,16"
                    BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1" Translation="0,0,16">
                <Border.Shadow><ThemeShadow /></Border.Shadow>
                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" FontFamily="{StaticResource GeistMonoFamily}"
                               FontSize="64" FontWeight="Bold" CharacterSpacing="-20" HorizontalAlignment="Center">
                        <TextBlock.Foreground><SolidColorBrush Color="{x:Bind ViewModel.CountdownColor, Mode=OneWay}" /></TextBlock.Foreground>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                            <Ellipse.Fill><SolidColorBrush Color="{x:Bind ViewModel.CountdownColor, Mode=OneWay}" /></Ellipse.Fill>
                        </Ellipse>
                        <TextBlock FontSize="15" Foreground="{ThemeResource GeistGray700Brush}">
                            <Run Text="{x:Bind L_Until}" /><Run Text=" " />
                            <Run Text="{x:Bind ViewModel.NextPrayerName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{ThemeResource GeistGray1000Brush}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ ROW 2: All done ═══ -->
            <Border Grid.Row="2" Visibility="{x:Bind ViewModel.AllPrayersPassed, Mode=OneWay}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="16" Padding="32,36" Margin="0,0,0,16"
                    BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE73E;" FontSize="40" Foreground="{ThemeResource GeistSuccessBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind L_AllCompleted}" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource GeistGray1000Brush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind L_AllCompletedMsg}" FontSize="14" Foreground="{ThemeResource GeistGray700Brush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ═══ ROW 3: No location ═══ -->
            <Border Grid.Row="3" Visibility="{x:Bind ViewModel.HasLocation, Mode=OneWay, Converter={StaticResource InvertBoolVis}}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="16" Padding="32,40" Margin="0,0,0,16"
                    BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE81D;" FontSize="40" Foreground="{ThemeResource GeistGray600Brush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind L_SetLocation}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource GeistGray1000Brush}" />
                    <TextBlock Text="{x:Bind L_SetLocationDesc}" FontSize="14" Foreground="{ThemeResource GeistGray700Brush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- ═══ ROW 4: Error ═══ -->
            <InfoBar Grid.Row="4" IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}" Severity="Error" Title="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Margin="0,0,0,12" />

            <!-- ═══ ROW 5: Shutdown Info ═══ -->
            <Border Grid.Row="5" Visibility="{x:Bind ViewModel.ShowShutdownInfo, Mode=OneWay}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7E8;" FontSize="16" Foreground="{ThemeResource GeistGray700Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind L_ShutdownHow}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource GeistGray1000Brush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Style="{StaticResource GeistButtonTertiaryStyle}" HorizontalAlignment="Right" Width="28" Height="28" Padding="0" Command="{x:Bind ViewModel.DismissShutdownInfoCommand}">
                            <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{ThemeResource GeistGray600Brush}" />
                        </Button>
                    </Grid>
                    <StackPanel Spacing="6" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10"><Ellipse Width="6" Height="6" Fill="{ThemeResource GeistBlue700Brush}" VerticalAlignment="Center" Margin="3,0" /><TextBlock Text="{x:Bind ViewModel.ShutdownStep1, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource GeistGray900Brush}" TextWrapping="Wrap" /></StackPanel>
                        <Border Width="2" Height="6" Background="{ThemeResource GeistGray400Brush}" HorizontalAlignment="Left" Margin="5,0" CornerRadius="1" />
                        <StackPanel Orientation="Horizontal" Spacing="10"><Ellipse Width="6" Height="6" Fill="{ThemeResource GeistWarningBrush}" VerticalAlignment="Center" Margin="3,0" /><TextBlock Text="{x:Bind ViewModel.ShutdownStep2, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource GeistGray900Brush}" TextWrapping="Wrap" /></StackPanel>
                        <Border Width="2" Height="6" Background="{ThemeResource GeistGray400Brush}" HorizontalAlignment="Left" Margin="5,0" CornerRadius="1" />
                        <StackPanel Orientation="Horizontal" Spacing="10"><Ellipse Width="6" Height="6" Fill="{ThemeResource GeistErrorBrush}" VerticalAlignment="Center" Margin="3,0" /><TextBlock Text="{x:Bind ViewModel.ShutdownStep3, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource GeistGray900Brush}" TextWrapping="Wrap" /></StackPanel>
                        <Border Width="2" Height="6" Background="{ThemeResource GeistGray400Brush}" HorizontalAlignment="Left" Margin="5,0" CornerRadius="1" />
                        <StackPanel Orientation="Horizontal" Spacing="10"><Ellipse Width="6" Height="6" Fill="{ThemeResource GeistSuccessBrush}" VerticalAlignment="Center" Margin="3,0" /><TextBlock Text="{x:Bind ViewModel.ShutdownStep4, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource GeistGray900Brush}" TextWrapping="Wrap" /></StackPanel>
                    </StackPanel>
                    <Button Content="{x:Bind L_GotIt}" Style="{StaticResource GeistButtonSecondaryStyle}" HorizontalAlignment="Stretch" Height="34" Command="{x:Bind ViewModel.DismissShutdownInfoCommand}" />
                </StackPanel>
            </Border>

            <!-- ═══ ROW 6: Enhanced Progress Bar ═══ -->
            <Border Grid.Row="6" Visibility="{x:Bind ViewModel.ShowPrayerProgress, Mode=OneWay}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="16,14"
                    Margin="0,0,0,10" BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <!-- Header: From → To with percentage -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource GeistGray600Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.ProgressFromName, Mode=OneWay}" FontSize="12" FontWeight="Medium" Foreground="{ThemeResource GeistGray900Brush}" />
                            <TextBlock Text="{x:Bind ViewModel.ProgressElapsed, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource GeistGray600Brush}" FontFamily="{StaticResource GeistMonoFamily}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                            <TextBlock Text="{x:Bind ViewModel.ProgressRemaining, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource GeistGray600Brush}" FontFamily="{StaticResource GeistMonoFamily}" />
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource GeistBlue700Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.ProgressToName, Mode=OneWay}" FontSize="12" FontWeight="Medium" Foreground="{ThemeResource GeistGray1000Brush}" />
                        </StackPanel>
                    </Grid>
                    <!-- Bar -->
                    <Grid>
                        <ProgressBar Minimum="0" Maximum="1" Value="{x:Bind ViewModel.PrayerProgressPercent, Mode=OneWay}"
                                     Height="6" CornerRadius="3" IsIndeterminate="False"
                                     Foreground="{ThemeResource GeistBlue700Brush}" Background="{ThemeResource GeistGray200Brush}" />
                    </Grid>
                    <!-- Percentage label centered -->
                    <TextBlock Text="{x:Bind ViewModel.ProgressPercentText, Mode=OneWay}"
                               FontSize="11" FontWeight="Medium" Foreground="{ThemeResource GeistGray600Brush}"
                               FontFamily="{StaticResource GeistMonoFamily}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ═══ ROW 7: Enhanced Day Timeline ═══ -->
            <Border Grid.Row="7" Visibility="{x:Bind ViewModel.HasLocation, Mode=OneWay}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="16,12"
                    Margin="0,0,0,10" BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <!-- Time labels row -->
                    <Grid>
                        <TextBlock Text="00:00" FontSize="10" Foreground="{ThemeResource GeistGray600Brush}"
                                   FontFamily="{StaticResource GeistMonoFamily}" HorizontalAlignment="Left" />
                        <TextBlock Text="12:00" FontSize="10" Foreground="{ThemeResource GeistGray600Brush}"
                                   FontFamily="{StaticResource GeistMonoFamily}" HorizontalAlignment="Center" />
                        <TextBlock Text="24:00" FontSize="10" Foreground="{ThemeResource GeistGray600Brush}"
                                   FontFamily="{StaticResource GeistMonoFamily}" HorizontalAlignment="Right" />
                    </Grid>
                    <!-- Track + dots (base track in XAML, progress + dots in Canvas) -->
                    <Grid Height="36">
                        <Border Height="3" VerticalAlignment="Top" Margin="0,8.5,0,0" CornerRadius="1.5"
                                Background="{ThemeResource GeistGray200Brush}" />
                        <Canvas x:Name="TimelineCanvas" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ ROW 8: Section header ═══ -->
            <Grid Grid.Row="8" Margin="0,0,0,10" Visibility="{x:Bind ViewModel.HasLocation, Mode=OneWay}">
                <TextBlock Text="{x:Bind L_TodaysPrayers}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource GeistGray1000Brush}" VerticalAlignment="Center" />
                <TextBlock Text="{x:Bind L_Shutdown}" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource GeistGray600Brush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <!-- ═══ ROW 9: Prayer cards (Features 1, 3) ═══ -->
            <ItemsRepeater Grid.Row="9" ItemsSource="{x:Bind ViewModel.Prayers, Mode=OneWay}" Visibility="{x:Bind ViewModel.HasLocation, Mode=OneWay}">
                <ItemsRepeater.Layout><StackLayout Spacing="3" /></ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:PrayerCardModel">
                        <Border Padding="12,10,12,10" CornerRadius="10" BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1" Opacity="{x:Bind CardOpacity, Mode=OneWay}">
                            <Border.Background><SolidColorBrush Color="{ThemeResource GeistBackground200}" /></Border.Background>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Accent bar -->
                                <Border Grid.Column="0" Width="{x:Bind AccentWidth, Mode=OneWay}" Height="22" CornerRadius="2" VerticalAlignment="Center">
                                    <Border.Background><SolidColorBrush Color="{x:Bind AccentColor, Mode=OneWay}" /></Border.Background>
                                </Border>

                                <!-- Name + badges -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                                    <TextBlock Text="{x:Bind LocalizedName, Mode=OneWay}" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource GeistGray1000Brush}" />
                                    <TextBlock Text="{x:Bind ShutdownBadgeText, Mode=OneWay}" FontSize="10" Foreground="{ThemeResource GeistWarningBrush}" Visibility="{x:Bind ShutdownEnabled, Mode=OneWay}" />
                                </StackPanel>

                                <!-- Time -->
                                <TextBlock Grid.Column="2" Text="{x:Bind TimeFormatted}" FontFamily="{StaticResource GeistMonoFamily}" FontSize="14" Foreground="{ThemeResource GeistGray900Brush}" VerticalAlignment="Center" />

                                <!-- Status badge -->
                                <Border Grid.Column="3" CornerRadius="9999" Padding="8,3" VerticalAlignment="Center" Visibility="{x:Bind IsActionable}">
                                    <Border.Background><SolidColorBrush Color="{x:Bind StatusColor, Mode=OneWay}" Opacity="0.12" /></Border.Background>
                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" FontSize="11" FontWeight="Medium">
                                        <TextBlock.Foreground><SolidColorBrush Color="{x:Bind StatusColor, Mode=OneWay}" /></TextBlock.Foreground>
                                    </TextBlock>
                                </Border>

                                <!-- Shutdown toggle -->
                                <Button Grid.Column="4" Visibility="{x:Bind IsActionable}" Command="{x:Bind ToggleShutdownCommand}"
                                        Style="{StaticResource GeistButtonTertiaryStyle}" Width="32" Height="32" Padding="0" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE7E8;" FontSize="14">
                                        <FontIcon.Foreground><SolidColorBrush Color="{x:Bind ShutdownIconColor, Mode=OneWay}" /></FontIcon.Foreground>
                                    </FontIcon>
                                </Button>

                                <!-- "I Prayed" button -->
                                <Button Grid.Column="5" Visibility="{x:Bind CanMarkPrayed, Mode=OneWay}"
                                        Command="{x:Bind MarkAsPrayedCommand}"
                                        Style="{StaticResource GeistButtonTertiaryStyle}" Width="32" Height="32" Padding="0"
                                        VerticalAlignment="Center" ToolTipService.ToolTip="{x:Bind PrayedTooltip}">
                                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource GeistSuccessBrush}" />
                                </Button>
                                <!-- Undo button (5 sec window) -->
                                <Button Grid.Column="5" Visibility="{x:Bind CanUndo, Mode=OneWay}"
                                        Command="{x:Bind UndoPrayedCommand}"
                                        Style="{StaticResource GeistButtonTertiaryStyle}" Width="32" Height="32" Padding="0"
                                        VerticalAlignment="Center" ToolTipService.ToolTip="{x:Bind UndoTooltip}">
                                    <FontIcon Glyph="&#xE7A7;" FontSize="14" Foreground="{ThemeResource GeistWarningBrush}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ═══ ROW 10: Daily Wisdom (Feature 5) ═══ -->
            <Border Grid.Row="10" Visibility="{x:Bind ViewModel.ShowWisdom, Mode=OneWay}"
                    Background="{ThemeResource GeistBackground200Brush}" CornerRadius="12" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{ThemeResource GeistGrayAlpha100Brush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE82D;" FontSize="13" Foreground="{ThemeResource GeistGray700Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind L_WisdomTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource GeistGray900Brush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Style="{StaticResource GeistButtonTertiaryStyle}" HorizontalAlignment="Right" Width="28" Height="28" Padding="0" Command="{x:Bind ViewModel.DismissWisdomCommand}">
                            <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{ThemeResource GeistGray600Brush}" />
                        </Button>
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.WisdomText, Mode=OneWay}" FontSize="13" FontStyle="Italic" Foreground="{ThemeResource GeistGray900Brush}" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.WisdomSource, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource GeistGray600Brush}" />
                </StackPanel>
            </Border>

            <!-- ═══ ROW 11: Loading ═══ -->
            <ProgressRing Grid.Row="11" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,32,0,0" />
        </Grid>
    </ScrollViewer>
</Page>
