<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrayerShutdown.UI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <StackPanel Padding="32,24,32,32" Spacing="24"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MaxWidth="400">

        <Image Source="ms-appx:///Assets/icon.svg"
               Width="96" Height="96"
               HorizontalAlignment="Center" />

        <TextBlock Text="{x:Bind Title}"
                   Style="{StaticResource GeistHeading2Style}"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{x:Bind Version}"
                   Style="{StaticResource GeistBodySmallStyle}"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{x:Bind Description}"
                   TextWrapping="Wrap" TextAlignment="Center"
                   Style="{StaticResource GeistBodyDefaultStyle}" />

        <Border Height="1" Background="{ThemeResource GeistGray400Brush}" Opacity="0.3" />

        <StackPanel Spacing="4" HorizontalAlignment="Center">
            <TextBlock Text="{x:Bind Tech}"
                       Style="{StaticResource GeistBodySmallStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind Algorithm}"
                       Style="{StaticResource GeistBodySmallStyle}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </StackPanel>
</Page>
