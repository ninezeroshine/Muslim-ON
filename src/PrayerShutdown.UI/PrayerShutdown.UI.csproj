<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <RootNamespace>PrayerShutdown.UI</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <Platforms>x64;x86;ARM64</Platforms>
    <RuntimeIdentifiers>win-x64;win-x86;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
    <EnableMsixTooling>false</EnableMsixTooling>
    <AppxPackage>false</AppxPackage>
    <!--
      Single-instance enforcement: replace the auto-generated Main with our own
      Program.cs that calls AppInstance.FindOrRegisterForKey before starting the
      Application. See src/PrayerShutdown.UI/Program.cs for details.
    -->
    <DefineConstants>$(DefineConstants);DISABLE_XAML_GENERATED_MAIN</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PrayerShutdown.Core\PrayerShutdown.Core.csproj" />
    <ProjectReference Include="..\PrayerShutdown.Common\PrayerShutdown.Common.csproj" />
    <ProjectReference Include="..\PrayerShutdown.Services\PrayerShutdown.Services.csproj" />
    <ProjectReference Include="..\PrayerShutdown.Features\PrayerShutdown.Features.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" />
    <PackageReference Include="H.NotifyIcon.WinUI" />
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Serilog.Extensions.Hosting" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="Serilog.Sinks.Debug" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\**" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Fonts\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!--
    Fix for unpackaged WinUI 3: dotnet publish doesn't copy .xbf files (compiled XAML).
    Without this, Application.LoadComponent throws XamlParseException at runtime for
    secondary windows (PrayerOverlayWindow) and any Page/Window whose XBF isn't on disk.
    See: https://github.com/microsoft/microsoft-ui-xaml/issues for known issue.
  -->
  <Target Name="CopyXbfToPublish" AfterTargets="_CopyResolvedFilesToPublishAlways;_CopyResolvedFilesToPublishPreserveNewest">
    <ItemGroup>
      <_XbfFiles Include="$(OutDir)**\*.xbf" />
    </ItemGroup>
    <Copy
      SourceFiles="@(_XbfFiles)"
      DestinationFiles="@(_XbfFiles->'$(PublishDir)%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />
  </Target>
</Project>
